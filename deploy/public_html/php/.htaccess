# ==================================================
# PREMIER LUMBER CO - PHP FOLDER PROTECTION
# Hostinger & Linux Compatible
# ==================================================

# 1. DENY DIRECT ACCESS TO PHP FILES
# PHP files should only be accessed via form submissions
<FilesMatch "\.php$">
    # Allow POST requests only (for form submissions)
    <If "%{REQUEST_METHOD} != 'POST'">
        Require all denied
    </If>
</FilesMatch>

# 2. PREVENT DIRECTORY LISTING
Options -Indexes

# 3. BLOCK ACCESS TO ALL NON-PHP FILES
<FilesMatch "\.(txt|log|json|csv|bak|old|sql|md)$">
    Require all denied
</FilesMatch>

# 4. SECURITY HEADERS FOR PHP RESPONSES
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set Cache-Control "no-store, no-cache, must-revalidate"
</IfModule>

# 5. BLOCK COMMON ATTACK PATTERNS
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block requests with malicious query strings
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete).*(from|into|table) [NC]
    RewriteRule ^.* - [F,L]

    # Block direct GET access - only POST allowed
    RewriteCond %{REQUEST_METHOD} !^POST$
    RewriteRule \.php$ - [F,L]
</IfModule>
